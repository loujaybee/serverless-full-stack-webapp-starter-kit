# --------------------------------------------------------------------------
# Local dev mode
# --------------------------------------------------------------------------
# Set both flags to "true" to bypass Cognito auth and stub all external AWS
# calls (Lambda async jobs, AppSync events). The app will run end-to-end
# against the local Postgres container without needing any deployed AWS
# resources. The two flags must match: the server-only flag drives the
# Server Action / Lambda / Cognito bypass; the NEXT_PUBLIC_ flag is needed
# so the client bundle skips Amplify configuration.
LOCAL_DEV_MODE=true
NEXT_PUBLIC_LOCAL_DEV_MODE=true

# Local Postgres started by `docker compose up -d` (or the postgres service
# in .ona/automations.yaml).
DATABASE_URL=postgresql://root:password@localhost:5432/postgres

# --------------------------------------------------------------------------
# Production / deployed config
# --------------------------------------------------------------------------
# The values below are only consumed when LOCAL_DEV_MODE is unset/false.
# In a deployed environment they are injected by CDK.
COGNITO_DOMAIN=auth.example.com
AMPLIFY_APP_ORIGIN=http://localhost:3010
USER_POOL_CLIENT_ID=dummy
USER_POOL_ID=us-west-2_dummy
NEXT_PUBLIC_EVENT_HTTP_ENDPOINT=""
NEXT_PUBLIC_AWS_REGION="us-west-2"
ASYNC_JOB_HANDLER_ARN=""
