# Set DEV_MODE=true to run without AWS (Cognito, Lambda, AppSync).
# A fixed local user is injected automatically. Translate jobs are no-ops.
# Do NOT set this in production.
DEV_MODE=true

# Cognito / Amplify — only required when DEV_MODE is not set.
COGNITO_DOMAIN=auth.example.com
AMPLIFY_APP_ORIGIN=http://localhost:3010
USER_POOL_CLIENT_ID=dummy
USER_POOL_ID=us-west-2_dummy

# AppSync Events — leave empty to disable real-time updates locally.
NEXT_PUBLIC_EVENT_HTTP_ENDPOINT=""
NEXT_PUBLIC_AWS_REGION="us-west-2"

# Async job Lambda — leave empty when DEV_MODE is set.
ASYNC_JOB_HANDLER_ARN=""
