# Set DEV_MODE=true to bypass Cognito auth and AWS service dependencies (Lambda, AppSync).
# Useful for local development without a deployed AWS stack.
# Do NOT set this in production.
DEV_MODE=false

COGNITO_DOMAIN=auth.example.com
AMPLIFY_APP_ORIGIN=http://localhost:3010
USER_POOL_CLIENT_ID=dummy
USER_POOL_ID=us-west-2_dummy
NEXT_PUBLIC_EVENT_HTTP_ENDPOINT=""
NEXT_PUBLIC_AWS_REGION="us-west-2"
ASYNC_JOB_HANDLER_ARN=""
